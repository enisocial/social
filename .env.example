# Supabase Configuration (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key
VITE_SUPABASE_PROJECT_ID=your_project_id

# Push Notifications (WonderPush) - OPTIONAL
# Get these from https://dashboard.wonderpush.com/
VITE_WONDERPUSH_WEB_KEY=your_wonderpush_web_key_here
WONDERPUSH_CLIENT_ID=your_wonderpush_client_id_here
WONDERPUSH_CLIENT_SECRET=your_wonderpush_client_secret_here

# Redis Cache (Upstash) - RECOMMANDÉ pour les performances
# Get these from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# Variables temporaires pour test (remplacer par vraies valeurs)
# UPSTASH_REDIS_REST_URL=https://skilled-ladybird-12345.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXYZ1234567890abcdefghijklmnopqrstuv

# Analytics et Monitoring - OPTIONAL
VITE_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# Sécurité - Production uniquement
VITE_ENABLE_DEVTOOLS=false
VITE_ENVIRONMENT=production
